{
  "mcpServers": {
    "wechat-devtools-bridge": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "./scripts/start-weapp-devtools-mcp.ps1"
      ],
      "env": {
        "WECHAT_PROJECT_PATH": ".",
        "WECHAT_DEVTOOLS_CLI": "",
        "WECHAT_WS_ENDPOINT": "ws://127.0.0.1:9420"
      }
    }
  }
}
